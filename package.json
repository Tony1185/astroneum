{
  "name": "@tony01/astroneum",
  "version": "0.4.1-beta.18",
  "packageManager": "pnpm@9.0.0",
  "description": "Astroneum - Professional financial charting library, ready out of the box.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "style": "./dist/astroneum.css",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./replay": {
      "types": "./dist/entries/replay.d.ts",
      "import": "./dist/entries/replay.js",
      "default": "./dist/entries/replay.js"
    },
    "./multichart": {
      "types": "./dist/entries/multichart.d.ts",
      "import": "./dist/entries/multichart.js",
      "default": "./dist/entries/multichart.js"
    },
    "./watchlist": {
      "types": "./dist/entries/watchlist.d.ts",
      "import": "./dist/entries/watchlist.js",
      "default": "./dist/entries/watchlist.js"
    },
    "./workspace": {
      "types": "./dist/entries/workspace.d.ts",
      "import": "./dist/entries/workspace.js",
      "default": "./dist/entries/workspace.js"
    },
    "./portfolio": {
      "types": "./dist/entries/portfolio.d.ts",
      "import": "./dist/entries/portfolio.js",
      "default": "./dist/entries/portfolio.js"
    },
    "./alerts": {
      "types": "./dist/entries/alerts.d.ts",
      "import": "./dist/entries/alerts.js",
      "default": "./dist/entries/alerts.js"
    },
    "./script": {
      "types": "./dist/entries/script.d.ts",
      "import": "./dist/entries/script.js",
      "default": "./dist/entries/script.js"
    },
    "./datafeeds/polygon": {
      "types": "./dist/entries/datafeeds/polygon.d.ts",
      "import": "./dist/entries/datafeeds/polygon.js",
      "default": "./dist/entries/datafeeds/polygon.js"
    },
    "./datafeeds/crypto": {
      "types": "./dist/entries/datafeeds/crypto.d.ts",
      "import": "./dist/entries/datafeeds/crypto.js",
      "default": "./dist/entries/datafeeds/crypto.js"
    },
    "./style.css": "./dist/astroneum.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/astroneum.css"
  ],
  "files": [
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "docs",
    "dist/**/*.js",
    "dist/**/*.css",
    "dist/**/*.d.ts"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tony1185/Astroneum.git"
  },
  "bugs": {
    "url": "https://github.com/Tony1185/Astroneum/issues"
  },
  "homepage": "https://github.com/Tony1185/Astroneum#readme",
  "keywords": [
    "astroneum",
    "candlestick",
    "candlestick-chart",
    "finance",
    "financial-chart",
    "stock",
    "trading",
    "technical-analysis",
    "indicators",
    "chart",
    "canvas",
    "webgl",
    "react",
    "typescript"
  ],
  "author": "kowito",
  "license": "MIT",
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "clean": "node -e \"const fs=require('node:fs');fs.rmSync('dist',{ recursive: true, force: true })\"",
    "build:js": "tsup --config tsup.config.ts",
    "build:css": "sass src/styles/index.scss src/styles/.tmp-astroneum.css --no-source-map && esbuild src/styles/.tmp-astroneum.css --bundle --minify --loader:.eot=dataurl --loader:.ttf=dataurl --loader:.woff=dataurl --loader:.svg=dataurl --outfile=dist/astroneum.css && node -e \"const fs=require('node:fs');fs.rmSync('src/styles/.tmp-astroneum.css',{ force: true })\"",
    "build": "pnpm clean && pnpm build:js && pnpm build:css",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/__tests__/*.test.ts",
    "test:watch": "tsx --test --watch src/__tests__/*.test.ts",
    "lint": "eslint src",
    "size": "size-limit",
    "verify": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "prepublishOnly": "pnpm verify"
  },
  "devDependencies": {
    "@size-limit/preset-big-lib": "^12.1.0",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@webgpu/types": "^0.1.69",
    "esbuild": "^0.25.11",
    "eslint": "^9.39.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "sass": "^1.0.0",
    "size-limit": "^12.1.0",
    "tsup": "^8.5.1",
    "tsx": "^4.20.6",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild"
    ]
  }
}
